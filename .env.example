# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Support contact shown to users when their account has been deleted
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Reroute pages to maintenance when applying production changes
NEXT_PUBLIC_MAINTENANCE_MODE=False

# E2E test credentials — create a test account in Supabase Auth and set these for local runs.
# Authenticated E2E is not run on CI (public tests only). When you add it, use a dedicated
# test Supabase project and inject SUPABASE_SERVICE_ROLE_KEY as a GitHub Actions secret.
TEST_USER_EMAIL=[YOUR_TEST_USER_EMAIL]
TEST_USER_PASSWORD=[YOUR_TEST_USER_PASSWORD]
