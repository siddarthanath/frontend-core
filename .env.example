# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API (required for Round 2+)
NEXT_PUBLIC_API_URL=http://localhost:8000

# E2E test credentials — must be a real user in your Supabase Auth project
# Create via: Supabase dashboard → Authentication → Users → Add user
TEST_USER_EMAIL=[YOUR_TEST_USER_EMAIL]
TEST_USER_PASSWORD=[YOUR_TEST_USER_PASSWORD]
